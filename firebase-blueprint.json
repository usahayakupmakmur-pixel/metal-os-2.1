        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["PAYMENT", "INCOME", "SPLITTER_AUTO", "TRASH_DEPOSIT", "PARKING_FEE", "WIFI_VOUCHER", "MARKET_SALE", "TOPUP"] },
